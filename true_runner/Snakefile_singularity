###########################################
# 1 — DOWNLOAD (NCBI)
###########################################
rule download_sequences:
    output:
        fasta="results/{virus}/{virus}_sequences.fasta",
        meta="results/{virus}/{virus}_metadata.tsv"
    params:
        query=lambda w: cfg[w.virus]["ncbi_query"],
        email=config["downloads"]["email"],
        virus="{virus}",
        minlength=lambda w: 2900 if w.virus == "HBV" else 8000,
        maxlength=lambda w: 3500 if w.virus == "HBV" else 11000
    conda: "envs/python.yaml"
    script:
        "scripts/download_sequences.py"

###########################################
# 2 — ALIGNMENT (MAFFT)
###########################################
rule align_mafft:
    input:
        seqs="results/{virus}/{virus}_sequences.fasta",
        refs=lambda w: cfg[w.virus]["refs"]
    output:
        "results/{virus}/aligned.fasta"
    conda: "envs/mafft.yaml"
    shell:
        r"""
        # Ensure reference headers are unique by prefixing with REF_<n>_
        awk 'BEGIN{{i=0}}
             /^>/ {{
                 i++;
                 gsub(/[^A-Za-z0-9_.-]/, "_", $0);
                 sub(/^>/, ">REF_" i "_", $0);
             }}
             {{print}}' {input.refs} \
          > results/{wildcards.virus}/refs_fixed.fasta

        # Combine sequences and fixed references
        cat {input.seqs} results/{wildcards.virus}/refs_fixed.fasta \
          > results/{wildcards.virus}/combined.fasta

        # Align
        mafft --auto --anysymbol --reorder results/{wildcards.virus}/combined.fasta \
          > {output}
        """

