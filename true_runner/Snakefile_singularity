###########################################
# 4 — PHYLOGENETICS (FastTree)
###########################################
rule clean_and_fasttree:
    input:
        "results/{virus}/aligned.fasta"
    output:
        "results/{virus}/aligned_clean.fasta.treefile"
    conda: "envs/fasttree.yaml"
    shell:
        """
        # Step 1: Clean the alignment by replacing ambiguous characters with N
        sed 's/[bdhkmnrsvwyBHKMNRSVWY]/N/g' {input} > {input}.cleaned
        
        # Step 2: Run FastTree on the cleaned alignment
        FastTree -nt {input}.cleaned > {output}
        """
# Annotate genotypes using reference sequences
rule annotate_genotypes:
    input:
        tree="results/{virus}/aligned_clean.fasta.treefile",
        metadata="results/{virus}_metadata.tsv"
    output:
        annotated="results/{virus}_annotated.tree",
        genotypes="results/{virus}_genotypes.csv"
    script:
        "scripts/annotate_genotypes.py"
###########################################
# Split fasta for GLUE
###########################################
rule split_fasta_per_sequence:
    input:
        "results/{virus}/{virus}_sequences.fasta"
    output:
        directory("results/{virus}/split_fasta")
    conda: "envs/python.yaml"
    shell:
        r"""
        mkdir -p {output}
        awk '
          /^>/ {{
            if (out) close(out);
            name = substr($1, 2);
            out = "{output}/" name ".fasta"
          }}
          {{ print > out }}
        ' {input}
        """

###########################################
# 5 — HBV GLUE Mutation Analysis
###########################################
rule hbv_glue:
    input:
        "results/hbv/split_fasta/{sample}.fasta"
    output:
        "results/hbv/glue/{sample}.xml"
    resources:
        gluemysql=1
    params:
        retries=3,
        sleep_time=10,
        timeout_sec=300
    shell:
        r"""
        set -euo pipefail

        SAMPLE="{wildcards.sample}"
        MAX_RETRIES={params.retries}
        SLEEP_TIME={params.sleep_time}
        TIMEOUT={params.timeout_sec}

        RETRY_COUNT=0
        CURRENT_DIR=$(pwd)

        while [ $RETRY_COUNT -lt $MAX_RETRIES ]; do

            echo "=== Processing $SAMPLE (Attempt $((RETRY_COUNT+1))/$MAX_RETRIES) ==="

            GLUE_CMD="/tmp/glue_cmd_${SAMPLE}.glue"

            cat > "$GLUE_CMD" << EOF
project hbv
console set log-level INFO
console set next-cmd-output-file /work/result.xml
module hdrReportingController invoke-function reportFastaCli /work/split_fasta/${SAMPLE}.fasta
EOF

            set +e
            timeout "$TIMEOUT" singularity run \
              --bind "$CURRENT_DIR/results/hbv:/work" \
              --bind "$GLUE_CMD:/tmp/glue_cmd.glue" \
              docker://cvrbioinformatics/gluetools:latest \
              gluetools.sh -f /tmp/glue_cmd.glue -n
            EXIT_CODE=$?
            set -e

            if [ "$EXIT_CODE" -eq 124 ]; then
                echo "⚠️  Timeout after ${TIMEOUT}s for $SAMPLE"
            fi

            if [ -f "results/hbv/result.xml" ]; then
                mv results/hbv/result.xml "{output}"
                rm -f "$GLUE_CMD"
                echo "✅ Success: {output}"
                exit 0
            fi

            echo "❌ Attempt $((RETRY_COUNT+1)) failed for $SAMPLE"
            rm -f results/hbv/result.xml "$GLUE_CMD"

            RETRY_COUNT=$((RETRY_COUNT+1))

            if [ $RETRY_COUNT -lt $MAX_RETRIES ]; then
                echo "⏳ Retrying in $SLEEP_TIME seconds..."
                sleep "$SLEEP_TIME"
            fi

        done

        echo "🚨 ERROR: All $MAX_RETRIES attempts failed for $SAMPLE"
        exit 1
        """

