###########################################
# Generate mutation tsv
###########################################
rule parse_glue_xml:
    input:
        xml="results/{virus}/glue/{sample}.xml"
    output:
        tsv="results/{virus}/resistance/{sample}.tsv"
    conda:
        "envs/python.yaml"
    shell:
        """
        mkdir -p results/{wildcards.virus}/resistance
        if [ "{wildcards.virus}" = "hbv" ]; then
            python scripts/parse_hbv_glue_xml.py {input.xml} {output.tsv}
        else
            python scripts/parse_hcv_glue_xml.py {input.xml} {output.tsv}
        fi
        """
        
rule merge_resistance_tables:
    input:
        lambda w: expand(
            "results/{virus}/resistance/{sample}.tsv",
            virus=w.virus,
            sample=(
                get_hbv_samples() if w.virus == "hbv" else get_hcv_samples()
            )
        )
    output:
        "results/{virus}/final_resistance.tsv"
    shell:
        """
        # Check if we have any input files
        if [ ! -d "results/{wildcards.virus}/resistance" ] || [ -z "$(ls -A results/{wildcards.virus}/resistance/*.tsv 2>/dev/null)" ]; then
            echo "No resistance data available" > {output}
            exit 0
        fi
        
        # Merge files
        head -n 1 $(ls results/{wildcards.virus}/resistance/*.tsv | head -1) > {output}
        tail -n +2 -q results/{wildcards.virus}/resistance/*.tsv >> {output}
        """

