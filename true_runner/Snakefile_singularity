import yaml
import glob
import os

configfile: "config.yaml"

cfg = config["viruses"]
VIRUSES = list(cfg.keys())

# Define functions to get samples dynamically (they'll be called when needed)
def get_hbv_samples():
    """Get HBV samples from split_fasta directory"""
    fasta_files = glob.glob("results/hbv/split_fasta/*.fasta")
    return [os.path.splitext(os.path.basename(f))[0] for f in fasta_files]

def get_hcv_samples():
    """Get HCV samples from split_fasta directory"""
    fasta_files = glob.glob("results/hcv/split_fasta/*.fasta")
    return [os.path.splitext(os.path.basename(f))[0] for f in fasta_files]

