# Enter the HBV project
project hbv

  # Suppress logging for cleaner output
  console set log-level OFF

  # Write the next command result to an XML file
  console set next-cmd-output-file /work/result.xml

  # Run resistance + genotyping analysis on a FASTA file
  module hdrReportingController invoke-function reportFastaCli /work/split_fasta/{{sample}}.fasta

exit

# Exit GLUE
exit

--platform linux/amd64

